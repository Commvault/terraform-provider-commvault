# Commvault Oracle Terraform Provider Test Configuration
# Copy this file to .env and update with your values
# Then load variables in PowerShell:
# Get-Content .env | ForEach-Object { if($_ -match '^([^=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }

# Enable acceptance tests (required)
TF_ACC=1

# Commvault Environment (REQUIRED - replace with your values)
CV_TEST_WEB_SERVICE_URL=https://your-commserve.example.com/webconsole/api
CV_TEST_USER_NAME=your-admin-username
CV_TEST_PASSWORD=your-admin-password

# Oracle Test Configuration (REQUIRED - replace with your values)
CV_TEST_CLIENT_NAME=your-oracle-client-name
CV_TEST_INSTANCE_NAME=YOUR_ORACLE_INSTANCE
CV_TEST_ORACLE_HOME=/path/to/oracle/home
CV_TEST_ORACLE_USER=oracle-os-user
